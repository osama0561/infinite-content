# Copy to .env (gitignored) and fill in real values.
# Env var NAMES are referenced from config.json's `secrets` block — change names there if you rename here.

# Required — used by Phases 2 (ideas) and 3 (script)
ANTHROPIC_API_KEY=

# Optional — only needed if you schedule via Publer in Phase 5
PUBLER_API_KEY=

# Optional — Google service account JSON path (Phase 5 Drive upload).
# Prefer setting `secrets.google_service_account_path` in config.json over this.
GOOGLE_APPLICATION_CREDENTIALS=
